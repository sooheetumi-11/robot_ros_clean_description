  <child link="dong_co_4"/>
</joint>

<!-- WHEEL BR: banh xe - co encoder -->
<joint name="wheel_br_joint" type="continuous">
  <origin xyz="0.0 0.05 0.0" rpy="0 0 0"/>
  <parent link="dong_co_4"/>
  <child link="banh_xe_4"/>
  <axis xyz="0.0 1.0 0.0"/>
</joint>

<!-- SENSORS -->
<joint name="fixed_lidar" type="fixed">
  <origin xyz="-0.15 0.1 0.08" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="ros_LiDar_1"/>
</joint>

<joint name="fixed_camera" type="fixed">
  <origin xyz="0.0 0.105 0.015" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="ros_camera_1"/>
</joint>

<!-- ENCODER: virtual link gan vao base_link -->
<joint name="encoder_joint" type="fixed">
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="encoder_link"/>
</joint>

<!-- ================================================================ -->
<!--              ROS2_CONTROL - HARDWARE INTERFACE                   -->
<!-- ================================================================ -->
<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gazebo_ros2_control/GazeboSystem</plugin>
  </hardware>

  <joint name="slider_joint">
    <command_interface name="position">
      <param name="min">-0.07</param>
      <param name="max">0.0</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="revolute_arm">
    <command_interface name="position">
      <param name="min">-1.570796</param>
      <param name="max">1.570796</param>
    </command_interface>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

<!-- Gazebo ros2_control plugin -->
<gazebo>
  <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
    <parameters>$(find robot_ros_clean_description)/config/controllers.yaml</parameters>
  </plugin>
</gazebo>

</robot>