<!-- ================================================================ -->
<!--                           JOINTS                                  -->
<!-- ================================================================ -->

<!-- ARM: fixed base -->
<joint name="fixed_arm_base" type="fixed">
  <origin xyz="-0.04 0.07 0.08" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="ros_base_arm_1"/>
</joint>

<!-- ARM: Khop 1 - Tinh tien (Prismatic) - KHOP P -->
<joint name="slider_joint" type="prismatic">
  <origin xyz="-0.025 0.03 0.103" rpy="0 0 0"/>
  <parent link="ros_base_arm_1"/>
  <child link="ros_link1_1"/>
  <axis xyz="0.0 0.0 1.0"/>
  <limit upper="0.0" lower="-0.07" effort="100" velocity="100"/>
</joint>

<!-- ARM: Khop 2 - Quay (Revolute) - KHOP R -->
<joint name="revolute_arm" type="revolute">
  <origin xyz="0.07 -0.0015 -0.01" rpy="0 0 0"/>
  <parent link="ros_link1_1"/>
  <child link="ros_link2_1"/>
  <axis xyz="0.0 1.0 0.0"/>
  <limit upper="1.570796" lower="-1.570796" effort="100" velocity="100"/>
</joint>

<!-- WHEEL FL: motor holder -->
<joint name="fixed_motor_holder_1" type="fixed">
  <origin xyz="-0.01 0.01 0.005" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="motor_holder_1"/>
</joint>

<joint name="fixed_dong_co_1" type="fixed">
  <origin xyz="-0.0215 0.013 0.0151" rpy="0 0 0"/>
  <parent link="motor_holder_1"/>
  <child link="dong_co_1"/>
</joint>

<!-- WHEEL FL: banh xe - co encoder -->
